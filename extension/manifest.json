{
  "manifest_version": 3,
  "name": "Tubemin",
  "version": "1.0.0",
  "description": "Send MeTube-supported URLs to your Tubemin server.",
  "permissions": ["activeTab", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "settings.html"
}
