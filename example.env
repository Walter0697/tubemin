# example.env — copy to .env and fill in values

# Tubemin server
API_PORT=3000
METUBE_URL=http://metube:8081
DOWNLOADS_DIR=/downloads
PEERTUBE_IMPORT_DIR=/peertube-import
DATABASE_URL=sqlite:///data/tubemin.db

# Auth mode: "oidc" (default) or "password"
# Use "password" for local testing without an OIDC provider
AUTH_MODE=oidc

# Password auth (only used when AUTH_MODE=password)
# ADMIN_PASSWORD=change-me

# OIDC provider (only used when AUTH_MODE=oidc, e.g. Authentik, Authelia, Keycloak)
OIDC_ISSUER_URL=https://auth.yourdomain.com/application/o/tubemin/
OIDC_CLIENT_ID=tubemin
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_REDIRECT_URL=https://tubemin.yourdomain.com/auth/callback

# Caddy domains
TUBEMIN_DOMAIN=tubemin.yourdomain.com
PEERTUBE_DOMAIN=peertube.yourdomain.com

# PeerTube database
PEERTUBE_DB_PASSWORD=change-me-strong-password
PEERTUBE_DB_USERNAME=peertube
PEERTUBE_DB_HOSTNAME=peertube_db
PEERTUBE_REDIS_HOSTNAME=peertube_redis
PEERTUBE_WEBSERVER_HOSTNAME=peertube.yourdomain.com
PEERTUBE_WEBSERVER_PORT=443
PEERTUBE_WEBSERVER_HTTPS=true
PEERTUBE_SECRET=generate-with-openssl-rand-hex-32
PEERTUBE_ADMIN_EMAIL=admin@yourdomain.com
PEERTUBE_ADMIN_PASSWORD=change-me-strong-password

# Tubemin → PeerTube auto-upload
# PEERTUBE_URL: internal Docker network address of PeerTube
# PEERTUBE_HOST: public hostname PeerTube is configured with (used for Host header validation)
PEERTUBE_URL=http://peertube:9000
PEERTUBE_HOST=peertube.yourdomain.com

# Bot account used for uploads — auto-created by Tubemin on first start
PEERTUBE_USERNAME=tubemin-bot
PEERTUBE_PASSWORD=change-me-bot-password

# PEERTUBE_ADMIN_PASSWORD is shared with PeerTube's own init (see above).
# Tubemin uses it + PEERTUBE_ADMIN_USERNAME (default: root) to provision the bot.
# You do not need to set PEERTUBE_ADMIN_USERNAME unless your admin is not root.
